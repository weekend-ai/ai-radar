# Postgres (docker-compose default)
DATABASE_URL=postgres://ai_radar:ai_radar@localhost:5433/ai_radar

# Redis (for BullMQ — added Week 1 Day 3)
REDIS_URL=redis://localhost:6380

# LLM (added Day 5)
OPENAI_API_KEY=
# Optional: route through an OpenAI-compatible gateway (LiteLLM, OpenRouter, Azure).
# Leave unset to talk to api.openai.com directly.
OPENAI_BASE_URL=
# Optional: model name used by enrichment worker.
# Defaults to gpt-4o-mini if unset. For LiteLLM gateway, try gpt-5.4-mini.
OPENAI_ENRICH_MODEL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
